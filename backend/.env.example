LLM_PROVIDER=openai_compatible
LLM_API_KEY=your_api_key_here
LLM_MODEL=qwen-max
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=1

# RAG / Chroma
CHROMA_DB_DIR=db/chroma_db
CHROMA_COLLECTION_NAME=travel_guides
EMBEDDING_MODEL=nomic-embed-text:latest
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=http://lpbkuaile5u:11434/
EMBEDDING_BATCH_SIZE=10

# Redis / Cache
REDIS_ENABLED=false
REDIS_URL=redis://127.0.0.1:6379/0
REDIS_KEY_PREFIX=trip_planner
REDIS_DEFAULT_TTL_SECONDS=1800
REDIS_WEATHER_TTL_SECONDS=1800
REDIS_MAP_TTL_SECONDS=86400
REDIS_RAG_TTL_SECONDS=21600

# Amap / Gaode Map
AMAP_API_KEY=your_amap_api_key
AMAP_BASE_URL=https://restapi.amap.com/v3
AMAP_DEFAULT_CITY=
AMAP_TIMEOUT_SECONDS=20
ENABLE_AMAP_ENRICHMENT=false

# Local life providers / Meituan-Dianping partner APIs
# These are optional partner endpoints. Leave empty to use Amap-only recommendations.
ENABLE_LOCAL_LIFE_ENRICHMENT=false
LOCAL_LIFE_TIMEOUT_SECONDS=20
MEITUAN_API_BASE_URL=
MEITUAN_API_KEY=
DIANPING_API_BASE_URL=
DIANPING_API_KEY=
